{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zettel",
  "version": "0.2.0",
  "identifier": "digital.laux.zettel",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zettel",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/dist/zettel-sidecar": "sidecar"
    },
    "category": "Business",
    "shortDescription": "Offline-first invoice generator",
    "longDescription": "Zettel — ZUGFeRD/Factur-X invoice generator for German freelancers and small businesses."
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:zettel.db"]
    }
  }
}
